#!/bin/bash
set -euo pipefail

echo "==> Installing packages..."

{{ if .isArch -}}
# Arch Linux - use pacman
sudo pacman -Syu --needed --noconfirm \
    bat eza fd fzf ripgrep zoxide \
    kitty btop fastfetch jq gum \
    starship lazygit yazi neovim zsh \
    ttf-nerd-fonts-symbols

{{ else if not .isArch -}}
# Ubuntu - use apt + external repos for missing packages

sudo apt-get update
sudo apt-get install -y \
    bat fd-find fzf ripgrep \
    kitty btop jq zsh curl git unzip \
    fontconfig xclip

# Create symlinks for renamed packages
[[ ! -L /usr/local/bin/bat ]] && sudo ln -sf /usr/bin/batcat /usr/local/bin/bat || true
[[ ! -L /usr/local/bin/fd ]] && sudo ln -sf /usr/bin/fdfind /usr/local/bin/fd || true

# Install eza
if ! command -v eza &>/dev/null; then
    sudo mkdir -p /etc/apt/keyrings
    wget -qO- https://raw.githubusercontent.com/eza-community/eza/main/deb.asc | sudo gpg --dearmor -o /etc/apt/keyrings/gierens.gpg
    echo "deb [signed-by=/etc/apt/keyrings/gierens.gpg] http://deb.gierens.de stable main" | sudo tee /etc/apt/sources.list.d/gierens.list
    sudo apt-get update && sudo apt-get install -y eza
fi

# Install zoxide
if ! command -v zoxide &>/dev/null; then
    curl -sSfL https://raw.githubusercontent.com/ajeetdsouza/zoxide/main/install.sh | sh
fi

# Install starship
if ! command -v starship &>/dev/null; then
    curl -sS https://starship.rs/install.sh | sh -s -- -y
fi

# Install lazygit
if ! command -v lazygit &>/dev/null; then
    LAZYGIT_VERSION=$(curl -s "https://api.github.com/repos/jesseduffield/lazygit/releases/latest" | jq -r '.tag_name' | sed 's/^v//')
    curl -Lo /tmp/lazygit.tar.gz "https://github.com/jesseduffield/lazygit/releases/download/v${LAZYGIT_VERSION}/lazygit_${LAZYGIT_VERSION}_Linux_x86_64.tar.gz"
    tar xf /tmp/lazygit.tar.gz -C /tmp lazygit
    sudo install /tmp/lazygit /usr/local/bin
    rm /tmp/lazygit /tmp/lazygit.tar.gz
fi

# Install yazi
if ! command -v yazi &>/dev/null; then
    YAZI_VERSION=$(curl -s "https://api.github.com/repos/sxyazi/yazi/releases/latest" | jq -r '.tag_name' | sed 's/^v//')
    curl -Lo /tmp/yazi.zip "https://github.com/sxyazi/yazi/releases/download/v${YAZI_VERSION}/yazi-x86_64-unknown-linux-gnu.zip"
    unzip -o /tmp/yazi.zip -d /tmp/yazi
    sudo install /tmp/yazi/yazi-x86_64-unknown-linux-gnu/yazi /usr/local/bin
    rm -rf /tmp/yazi /tmp/yazi.zip
fi

# Install gum
if ! command -v gum &>/dev/null; then
    sudo mkdir -p /etc/apt/keyrings
    curl -fsSL https://repo.charm.sh/apt/gpg.key | sudo gpg --dearmor -o /etc/apt/keyrings/charm.gpg
    echo "deb [signed-by=/etc/apt/keyrings/charm.gpg] https://repo.charm.sh/apt/ * *" | sudo tee /etc/apt/sources.list.d/charm.list
    sudo apt-get update && sudo apt-get install -y gum
fi

# Install neovim (latest stable)
if ! command -v nvim &>/dev/null; then
    curl -Lo /tmp/nvim-linux64.tar.gz "https://github.com/neovim/neovim/releases/latest/download/nvim-linux-x86_64.tar.gz"
    sudo rm -rf /opt/nvim
    sudo tar xf /tmp/nvim-linux64.tar.gz -C /opt
    sudo mv /opt/nvim-linux-x86_64 /opt/nvim
    rm /tmp/nvim-linux64.tar.gz
fi

# Install fastfetch
if ! command -v fastfetch &>/dev/null; then
    sudo add-apt-repository -y ppa:zhangsongcui3371/fastfetch
    sudo apt-get update && sudo apt-get install -y fastfetch
fi

{{ end -}}

echo "==> Package installation complete."
